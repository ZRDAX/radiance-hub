{
  "build": {
    "beforeDevCommand": "yarn dev",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "productName": "Randiance",
  "version": "0.1.0",
  "identifier": "bryanrochadel",
  "plugins": {
    "process": {
      "active": true
    }
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Randiance",
        "width": 400,
        "height": 560,
        "minWidth": 360,
        "maxWidth": 420,
        "decorations": false,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "fullscreen": false,
        "center": false,
        "dragDropEnabled": false
      }
    ]
  }
}
